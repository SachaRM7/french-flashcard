  "grammar": [
    {
      "id": "traditions-1-1:g0",
      "title": "أَنْتَ — Pronom personnel 2ème pers. masc. sing.",
      "titleFr": "Tu (masculin)",
      "explanation": "Utilisé pour s'adresser à un homme. Équivalent de 'tu' au masculin. En arabe, les pronoms varient selon le genre.",
      "examples": [
        {
          "ar": "أَنْتَ بريطاني.",
          "translit": "anta britani.",
          "fr": "Tu es Britannique.",
          "en": "You are British."
        },
        {
          "ar": "أَنْتَ تَعْبَان.",
          "translit": "anta ta'ban.",
          "fr": "Tu es fatigué.",
          "en": "You are tired."
        }
      ]
    },
    {
      "id": "traditions-1-1:g1",
      "title": "الجملة الاسمية — La phrase nominale",
      "titleFr": "Phrase nominale (pas de 'être' au présent)",
      "explanation": "En arabe, on n'utilise pas le verbe 'être' au présent. On juxtapose simplement sujet et attribut.",
      "examples": [
        {
          "ar": "أَنْتَ أَمِيرِكِيّ؟",
          "translit": "anta amiriki?",
          "fr": "Tu es américain ?",
          "en": "Are you American?"
        },
        {
          "ar": "هُوَ طَالِب.",
          "translit": "huwa talib.",
          "fr": "Il est étudiant.",
          "en": "He is a student."
        }
      ]
    }
  ],
